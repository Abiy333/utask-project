datasource db {
  provider = "postgresql" 
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  name      String?
  tasks     Task[]   
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(uuid())
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  userId      String   
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}